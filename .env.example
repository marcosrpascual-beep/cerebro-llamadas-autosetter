# ============================================================
# 🧠 CEREBRO DE LLAMADAS · variables de entorno
# Copia este archivo como .env y rellena con tus valores.
# En Railway, sube cada variable en el panel "Variables".
# ============================================================

# --- Claude (Anthropic) ---
# Sacar en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Telegram ---
# TOKEN: @BotFather en Telegram → /newbot → seguir instrucciones
# CHAT_ID: añade tu bot a un chat, manda un mensaje, abre:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
#   y mira "chat":{"id": ... }
TELEGRAM_TOKEN=1234567890:AAAA...
TELEGRAM_CHAT_ID=123456789

# --- Google OAuth (para crear Docs en TU Drive personal) ---
# Generar con el script scripts/get_refresh_token.py corriéndolo en local.
# Antes: crear OAuth Client tipo "Desktop app" en Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# --- Carpetas de Google Drive (IDs de la URL de cada carpeta) ---
# Ejemplo URL: https://drive.google.com/drive/folders/1ABC...XYZ
# El ID es la última parte (1ABC...XYZ).
FOLDER_VENTAS=
FOLDER_CLIENTES=
FOLDER_EQUIPO=
FOLDER_MAESTROS=
FOLDER_DATOS=    # carpeta oculta para los .json hermanos (mantiene VENTAS/CLIENTES/EQUIPO limpias)

# --- Doc maestro mensual ---
# Token aleatorio para proteger el endpoint /cron/maestro.
# Generar con: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
CRON_TOKEN=

# --- Fathom API (para el polling de fallback) ---
# Encontrar en: Fathom → Settings → Integrations → API
# La misma key del webhook vale. Sin esto, el polling no funciona y
# dependes solo del webhook de Fathom (que a veces no dispara).
FATHOM_API_KEY=
